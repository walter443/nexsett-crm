NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
SUPABASE_SECRET_KEY=YOUR_SERVER_ONLY_SECRET_KEY
NEXT_PUBLIC_SITE_URL=https://crm.nexsett.com
ALLOWED_GOOGLE_WORKSPACE_DOMAIN=nexsett.com

# Commission-review workflow email (server only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@nexsett.com
SMTP_PASS=YOUR_DEDICATED_GOOGLE_APP_PASSWORD
NOTIFICATION_FROM_NAME=Nexsett Information
NOTIFICATION_FROM_EMAIL=info@nexsett.com

# Protects the retry worker endpoint. Use a long random value.
CRON_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
